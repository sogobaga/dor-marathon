# Copy this file to .env and fill in values

# Server
ENV=development
PORT=8080

# PostgreSQL
# 本地開發：docker-compose 已內建本地 Postgres，無需在此設定。
# 雲端 DB（如 Neon）：複製此檔為 .env，並把 DATABASE_URL 設為雲端連線字串，
#   docker-compose 會自動覆寫 api/worker 的連線。雲端 DB 須加 ?sslmode=require。
# 範例（Neon）：
#   DATABASE_URL=postgres://<user>:<password>@<host>.neon.tech/<db>?sslmode=require
DATABASE_URL=postgres://dor:dor_dev_secret@localhost:5433/dor_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# AWS (production only)
AWS_REGION=ap-northeast-1
S3_BUCKET=dor-media

# Payment (mock in dev)
PAYMENT_PROVIDER=mock
# ECPAY_MERCHANT_ID=
# ECPAY_HASH_KEY=
# ECPAY_HASH_IV=
